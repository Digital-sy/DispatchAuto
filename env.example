# ─── 领星 ERP OpenAPI ───────────────────────────────────────────────
LINGXING_APP_KEY=
LINGXING_APP_SECRET=
LINGXING_BASE_URL=https://openapi.lingxing.com

# ─── 飞书自建应用 ────────────────────────────────────────────────────
# App ID 和 App Secret 已硬编码在 src/api/feishu/auth.js，无需填写
# 如需切换应用，在 auth.js 中修改

# ─── 仓库配置 ────────────────────────────────────────────────────────
DEFAULT_WID=10518

# ─── 测试模式 ────────────────────────────────────────────────────────
# TEST_MODE=true 时，所有飞书通知强制发给 TEST_RECEIVER，不影响真实运营
TEST_MODE=true
TEST_RECEIVER=刘宗霖

# ─── 通知配置 ────────────────────────────────────────────────────────
# 仓库通知对象（飞书姓名），发货计划通知运营负责人从领星数据自动读取
NOTIFY_WAREHOUSE_NAME=

# ─── 轮询配置 ────────────────────────────────────────────────────────
POLL_INTERVAL_CRON=*/5 * * * *
PACKING_WAIT_TIMEOUT_H=24
PLAN_CONFIRM_TIMEOUT_H=2
SHIPMENT_SYNC_RETRY=10
SHIPMENT_SYNC_INTERVAL_S=60
